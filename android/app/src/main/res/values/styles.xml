<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 主题 -->
    <style name="Theme.MarketingIME" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:colorPrimary">#1A73E8</item>
        <item name="android:colorAccent">#FF6D00</item>
        <item name="android:statusBarColor">#1A73E8</item>
    </style>

    <!-- 输入法键盘主题 -->
    <style name="KeyboardTheme" parent="android:Theme.DeviceDefault.InputMethod">
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>

    <!-- 颜色 -->
    <color name="primary">#1A73E8</color>
    <color name="primaryVariant">#1557B0</color>
    <color name="accent">#FF6D00</color>
    <color name="background">#FFFFFF</color>
    <color name="surface">#F5F5F5</color>
</resources>
